{
  // Type-CHECK only -- no emit, nothing in the build/runtime changes. The browser
  // (esbuild), the CLI, and the tests still run the same plain .js. Files opt in
  // with a `// @ts-check` comment (checkJs is off), so we can adopt types one hot
  // module at a time. Run with `npm run typecheck`.
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "strict": false,
    "noImplicitAny": false,
    // Rigor we can actually hold on gradually-typed JS. strictNullChecks is the flagship --
    // it catches null/undefined bugs (the #1 real JS bug class) and is now ENFORCED in CI
    // (npm run typecheck): new code must be null-safe or the build fails. Full strict /
    // noImplicitAny stays off (impractical -- ~1300 implicit-any across ~7k lines).
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["docs/**/*.js", "cli.mjs", "cli-common.mjs", "progression-cli.mjs", "types.d.ts"]
}
