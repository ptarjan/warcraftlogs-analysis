{
  // Type-CHECK only -- no emit, nothing in the build/runtime changes. The browser
  // (esbuild), the CLI, and the tests still run the same plain .js. Files opt in
  // with a `// @ts-check` comment (checkJs is off), so we can adopt types one hot
  // module at a time. Run with `npm run typecheck`.
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "strict": false,
    "noImplicitAny": false,
    // Catch dead code + missing returns (cheap rigor, no runtime change). Full strict /
    // noImplicitAny is impractical on gradually-typed JS (~1300 implicit-any), but these
    // two are free and catch real rot -- e.g. an unused import left after a refactor.
    "noUnusedLocals": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["docs/**/*.js", "cli.mjs", "cli-common.mjs", "progression-cli.mjs", "types.d.ts"]
}
