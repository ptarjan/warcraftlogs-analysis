# Create a WCL API client at: https://www.warcraftlogs.com/api/clients/
#
# These credentials live ONLY in the Cloudflare Worker, never in the browser.
#  - Production: `cd worker && npx wrangler secret put WCL_CLIENT_ID` (and SECRET)
#  - Local dev:  copy this file to `worker/.dev.vars` (gitignored)
WCL_CLIENT_ID=your-client-id-here
WCL_CLIENT_SECRET=your-client-secret-here
